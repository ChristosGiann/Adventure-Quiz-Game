    SPACE  \u03B3\u03B9\u03B1 \u03AC\u03BB\u03BC\u03B1\n\u039A\u03C1\u03AC\u03C4\u03B7\u03C3\u03B5
    \u03C4\u03BF  SHIFT  \u03B3\u03B9\u03B1 \u03BD\u03B1 \u03C4\u03C1\u03AD\u03BE\u03B5\u03B9\u03C2\n\u039A\u03C1\u03AC\u03C4\u03B7\u03C3\u03B5
    \u03C4\u03BF  TAB  \u03B3\u03B9\u03B1 \u03BA\u03BB\u03B5\u03AF\u03B4\u03C9\u03BC\u03B1
    \u03BA\u03AC\u03BC\u03B5\u03C1\u03B1\u03C2\n\u03A0\u03AC\u03C4\u03B7\u03C3\u03B5 
    E  \u03B3\u03B9\u03B1 \u03B1\u03BB\u03BB\u03B7\u03BB\u03B5\u03C0\u03AF\u03B4\u03C1\u03B1\u03C3\u03B7\n"
